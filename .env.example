# Storage backend
SOLARIS_STORE=sqlite
# For Postgres mode:
# SOLARIS_STORE=postgres
# DATABASE_URL=postgresql://user:pass@host:5432/solaris

# AI review providers
CODEX_REVIEW_ENABLED=true
GEMINI_REVIEW_ENABLED=true
# Set in secret manager, never commit real values
GEMINI_API_KEY=

# Demand NN settings (deferred in current VLM-first mode)
DEMAND_NN_ENABLED=false
# DEMAND_NN_MODEL_PATH=docs/models/demand_nn_v1.weights.json
# DEMAND_NN_METRICS_PATH=docs/models/demand_nn_v1.metrics.json
# DEMAND_NN_MAX_MAE=120.0
# DEMAND_NN_MAX_RMSE=140.0

# VLM-first heuristic sizing controls
PV_DERATE_FACTOR=0.8
PV_MIN_SUN_HOURS=2.5
PV_MAX_SUN_HOURS=7.5
BATTERY_AUTONOMY_DAYS=0.8
BATTERY_DOD=0.85
BATTERY_ROUNDTRIP_EFF=0.9
SOLAR_KIT_KWH_PER_DAY=1.2

# Spatial VLM agent settings
SPATIAL_VLM_PROVIDER=dashscope
SPATIAL_VLM_MODEL=qwen3-vl-plus
DASHSCOPE_API_KEY=
# Alternative: use OpenAI-compatible provider
# SPATIAL_VLM_PROVIDER=openai
# SPATIAL_VLM_MODEL=gpt-4o
# OPENAI_API_KEY=
SPATIAL_LOOKBACK_DAYS=90
SPATIAL_MAX_CLOUD_PCT=15
SPATIAL_BBOX_BUFFER=0.015
SPATIAL_JPEG_QUALITY=90

# Personalization + guardrail feature flags
GUARDRAILS_STRICT_MODE=true
POLICY_ROUTER_ENABLED=true
PERSONALIZATION_ENABLED=true

# Telegram review-ready notification
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
