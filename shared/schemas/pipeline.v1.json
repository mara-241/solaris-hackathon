{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Solaris Pipeline v1",
  "type": "object",
  "required": ["run_id", "request", "outputs", "evidence_pack"],
  "properties": {
    "run_id": { "type": "string" },
    "request": {
      "type": "object",
      "required": ["request_id", "lat", "lon", "horizon_days"],
      "properties": {
        "request_id": { "type": "string" },
        "lat": { "type": "number" },
        "lon": { "type": "number" },
        "horizon_days": { "type": "integer", "minimum": 1 },
        "households": { "type": "integer", "minimum": 1 },
        "usage_profile": { "type": "string" }
      }
    },
    "outputs": {
      "type": "object",
      "required": [
        "feature_context",
        "demand_forecast",
        "scenario_set",
        "optimization_result",
        "impact_metrics",
        "provenance",
        "quality"
      ],
      "properties": {
        "feature_context": {
          "type": "object",
          "required": ["status", "confidence", "assumptions", "quality_flags", "run_id"]
        },
        "demand_forecast": {
          "type": "object",
          "required": ["kwh_per_day", "lower_ci", "upper_ci"],
          "properties": {
            "kwh_per_day": { "type": "number" },
            "lower_ci": { "type": "number" },
            "upper_ci": { "type": "number" }
          }
        },
        "scenario_set": {
          "type": "object",
          "required": ["primary"],
          "properties": {
            "primary": {
              "type": "object",
              "required": ["pv_kw", "battery_kwh", "solar_kits"],
              "properties": {
                "pv_kw": { "type": "number" },
                "battery_kwh": { "type": "number" },
                "solar_kits": { "type": "integer", "minimum": 0 }
              }
            }
          }
        },
        "optimization_result": {
          "type": "object",
          "required": ["top_plan_id", "priority_score", "estimated_efficiency_gain_pct"],
          "properties": {
            "top_plan_id": { "type": "string" },
            "priority_score": { "type": "number", "minimum": 0, "maximum": 1 },
            "estimated_efficiency_gain_pct": { "type": "number" }
          }
        },
        "model_metadata": {
          "type": "object",
          "properties": {
            "model_input_version": { "type": "string" },
            "nn_used": { "type": "boolean" },
            "nn_model": { "type": ["string", "null"] },
            "nn_fallback_reason": { "type": ["string", "null"] }
          }
        },
        "impact_metrics": {
          "type": "object",
          "required": [
            "estimated_efficiency_gain_pct",
            "under_provisioning_risk_reduction_pct",
            "over_provisioning_waste_reduction_pct",
            "households_served_estimate",
            "co2_avoided_tons_estimate",
            "annual_cost_savings_usd_estimate",
            "confidence_score",
            "confidence_band",
            "assumptions"
          ],
          "properties": {
            "estimated_efficiency_gain_pct": { "type": "number" },
            "under_provisioning_risk_reduction_pct": { "type": "number" },
            "over_provisioning_waste_reduction_pct": { "type": "number" },
            "households_served_estimate": { "type": "integer", "minimum": 1 },
            "co2_avoided_tons_estimate": { "type": "number" },
            "annual_cost_savings_usd_estimate": { "type": "number" },
            "confidence_score": { "type": "number", "minimum": 0, "maximum": 1 },
            "confidence_band": { "type": "string", "enum": ["low", "medium", "high"] },
            "assumptions": { "type": "array", "items": { "type": "string" } }
          }
        },
        "provenance": {
          "type": "object",
          "required": ["weather_source", "demographics_source", "imagery_provider"],
          "properties": {
            "weather_source": { "type": ["string", "null"] },
            "demographics_source": { "type": ["string", "null"] },
            "imagery_provider": { "type": ["string", "null"] }
          }
        },
        "quality": {
          "type": "object",
          "required": ["status", "confidence", "fallback_used"],
          "properties": {
            "status": { "type": "string", "enum": ["ok", "degraded", "failed"] },
            "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
            "fallback_used": { "type": "boolean" }
          }
        }
      }
    },
    "evidence_pack": {
      "type": "object",
      "required": ["status", "confidence", "assumptions", "quality_flags", "run_id", "summary"]
    }
  }
}
